#--------Default config for HQ-RTR by Parsifal------
#Already setted config, just copy him in /openssh/ or rewrite with command cp /sshd_config /etc/openssh/sshd_config : yes

# Все самое нужное
Port 2024
ListenAddress 0.0.0.0
ListenAddress ::
AllowUsers sshuser
Banner /etc/banner

# Аутентификация
LoginGraceTime 2m
PermitRootLogin yes
StrictModes yes
MaxAuthTries 6
MaxSessions 10

# Парольная аутентификация
PasswordAuthentication yes
PermitEmptyPasswords no

#Настройки публичных ключей
PubkeyAuthentication yes
AuthorizedKeysFile .ssh/authorized_keys

# Ключи хоста
HostKey /etc/ssh/ssh_host_rsa_key
HostKey /etc/ssh/ssh_host_ecdsa_key
HostKey /etc/ssh/ssh_host_ed25519_key

# Логирование
SyslogFacility AUTH
LogLevel INFO

UsePAM yes

# X11 (обычно не нужно)
#X11Forwarding no
#X11DisplayOffset 10
#X11UseLocalhost yes

# TCP forwarding
#AllowTcpForwarding yes
#GatewayPorts no
#PermitTunnel no

# Keepalive
ClientAliveInterval 0
ClientAliveCountMax 3

# SFTP
Subsystem sftp /usr/lib/ssh/sftp-server

# Прочее
PrintMotd no
AcceptEnv LANG LC_*